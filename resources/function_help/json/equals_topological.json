{
  "name": "equals_topological",
  "type": "function",
  "groups": [
    "GeometryGroup"
  ],
  "description": "Tests whether two geometries are topologically equal. Returns TRUE if geometry1 is topologically equal to geometry2.",
  "arguments": [
    {
      "arg": "geometry1",
      "description": "a geometry"
    },
    {
      "arg": "geometry2",
      "description": "a geometry"
    },
    {
      "arg": "backend",
      "optional": true,
      "default": "GEOS",
      "description": "Available geometry backend implementations: GEOS"
    }
  ],
  "examples": [
    {
      "expression": "equals_topological( geom_from_wkt( 'POINT( 0 0 )' ), geom_from_wkt( 'POINT( 0 0 )' ) )",
      "returns": "TRUE"
    },
    {
      "expression": "equals_topological( geom_from_wkt( 'POINT( 0 0 )' ), geom_from_wkt( 'POINT( 0 0 )' ), 'GEOS' )",
      "returns": "TRUE"
    },
    {
      "expression": "equals_topological( geom_from_wkt( 'POINT( 0 0 )' ), geom_from_wkt( 'MULTIPOINT( ( 0 0 ) )' ) )",
      "returns": "TRUE"
    },
    {
      "expression": "equals_topological( geom_from_wkt( 'POINT( 0 0 )' ), geom_from_wkt( 'MULTIPOINT( ( 0 0 ) )' ), 'GEOS' )",
      "returns": "TRUE"
    },
    {
      "expression": "equals_topological( geom_from_wkt( 'LINESTRING( 0 0, 1 1 )' ), geom_from_wkt( 'LINESTRING( 0 0, 1 1 )' ) )",
      "returns": "TRUE"
    }
  ],
  "tags": [
    "tests",
    "equal",
    "equals",
    "topologically",
    "equals_topological"
  ]
}