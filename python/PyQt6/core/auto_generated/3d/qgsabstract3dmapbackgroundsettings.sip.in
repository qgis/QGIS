class QgsAbstract3DMapBackgroundSettings : QgsAbstract3DAsset
{
%Docstring(signature="appended")
Base class for all background settings classes used in a 3D map view.

:py:class:`QgsAbstract3DMapBackgroundSettings` subclasses are
responsible for storing the configuration of different background types
(skybox, gradient).

.. versionadded:: 4.2
%End

%TypeHeaderCode
#include "qgsabstract3dmapbackgroundsettings.h"
%End
  public:
    virtual Qgis::Asset3DType assetType() const;

    virtual Qgis::Map3DBackgroundType type() const = 0;
%Docstring
Returns the unique type for this background settings class.
%End

    virtual QgsAbstract3DMapBackgroundSettings *clone() const = 0 /Factory/;
%Docstring
Returns a deep copy of this background settings object.
%End
};

