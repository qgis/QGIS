%Docstring
Returns ``True`` if the specified ``technique`` is supported by the
material.
%End

    static QgsAbstractMaterialSettings *create() /Factory/;
%Docstring
Returns a new instance of QgsUnlitMaterialSettings.
%End

    virtual QgsUnlitMaterialSettings *clone() const /Factory/;

    virtual bool equals( const QgsAbstractMaterialSettings *other ) const;

    virtual QSet< QgsAbstractMaterialSettings::Property > supportedProperties() const;


    QColor color() const;
%Docstring
Returns the material color.

.. seealso:: :py:func:`setColor`
%End

    void setColor( const QColor &color );
%Docstring
Sets the material's ``color``.

.. seealso:: :py:func:`color`
%End

    virtual QColor averageColor() const;

    virtual void setColorsFromBase( const QColor &baseColor );


    virtual void readXml( const QDomElement &elem, const QgsReadWriteContext &context );

    virtual void writeXml( QDomElement &elem, const QgsReadWriteContext &context ) const;


    bool operator==( const QgsUnlitMaterialSettings &other ) const;

};


