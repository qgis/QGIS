class QgsMetalRoughTexturedMaterialSettings : QgsAbstractMaterialSettings
{
%Docstring(signature="appended")
A PBR metal rough shading material used for rendering with support for
image texture maps.

.. warning::

   This is not considered stable API, and may change in future QGIS releases. It is
   exposed to the Python bindings as a tech preview only.

.. versionadded:: 4.2
%End

%TypeHeaderCode
#include "qgsmetalroughtexturedmaterialsettings.h"
%End
  public:
