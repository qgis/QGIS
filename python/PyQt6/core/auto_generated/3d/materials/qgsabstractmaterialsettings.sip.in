class QgsAbstractMaterialSettings : QgsAbstract3DAsset
{
%Docstring(signature="appended")
Abstract base class for material settings.

.. warning::

   This is not considered stable API, and may change in future QGIS releases. It is
   exposed to the Python bindings as a tech preview only.
%End

%TypeHeaderCode
#include "qgsabstractmaterialsettings.h"
%End
  public:
    virtual Qgis::Asset3DType assetType() const;


    virtual QString type() const = 0;
%Docstring
Returns the unique type name for the material.
%End

    virtual bool requiresTextureCoordinates() const;
%Docstring
Returns ``True`` if the material requires texture coordinates to be
generated during triangulation.

.. versionadded:: 4.2
%End

    virtual bool requiresTangents() const;
%Docstring
Returns ``True`` if the material requires tangents generated during
triangulation.

.. versionadded:: 4.2
%End

    enum class Property /BaseType=IntEnum/
    {
      Diffuse,
      Ambient,
      Warm,
      Cool,
      Specular
    };

    void setDataDefinedProperties( const QgsPropertyCollection &collection );
%Docstring
Sets the material property collection, used for data defined overrides.

.. versionadded:: 4.2
%End

    QgsPropertyCollection dataDefinedProperties() const;
%Docstring
Returns the symbol material property collection, used for data defined
overrides.

.. versionadded:: 4.2
%End

    const QgsPropertiesDefinition &propertyDefinitions() const;
%Docstring
Returns a reference to the material properties definition, used for data
defined overrides.

.. versionadded:: 4.2
%End
    virtual QgsAbstractMaterialSettings *clone() const = 0 /Factory/;

    virtual void readXml( const QDomElement &element, const QgsReadWriteContext &context );

    virtual void writeXml( QDomElement &element, const QgsReadWriteContext &context ) const;


};


