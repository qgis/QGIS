class QgsSimpleCurve : QgsCurve /Abstract/
{
%Docstring(signature="appended")
Abstract base class for simple curved geometry type.

This class is not part of the SQL/MM standard and only exists for
implementation convenience.

.. versionadded:: 4.4
%End

%TypeHeaderCode
#include "qgssimplecurve.h"
%End
  public:
    QgsSimpleCurve();


  SIP_PYOBJECT pointN( int i ) const /TypeHint="QgsPoint"/;
%Docstring
Returns the point at the specified index.

- Indexes can be less than 0, in which case they correspond to positions
  from the end of the simple curve. E.g. an index of -1

corresponds to the last point in the simple curve.

:raises IndexError: if no point with the specified index exists.
%End
%MethodCode
      const int count = sipCpp->numPoints();
  if ( a0 < -count || a0 >= count )
  {
    PyErr_SetString( PyExc_IndexError, QByteArray::number( a0 ) );
    sipIsErr = 1;
  }
  else
  {
    std::unique_ptr< QgsPoint > p;
    if ( a0 >= 0 )
      p = std::make_unique< QgsPoint >( sipCpp->pointN( a0 ) );
    else // negative index, count backwards from end
      p = std::make_unique< QgsPoint >( sipCpp->pointN( count + a0 ) );
    sipRes = sipConvertFromType( p.release(), sipType_QgsPoint, Py_None );
  }
%End









    virtual int numPoints() const /HoldGIL/;

    virtual int nCoordinates() const /HoldGIL/;

    virtual int dimension() const /HoldGIL/;


    virtual bool addMValue( double mValue = 0 );

    virtual bool addZValue( double zValue = 0 );

    virtual bool dropMValue();

    virtual bool dropZValue();


    virtual QgsPoint startPoint() const /HoldGIL/;

    virtual QgsPoint endPoint() const /HoldGIL/;


    virtual bool moveVertex( QgsVertexId position, const QgsPoint &newPos );

    virtual QgsSimpleCurve *reversed() const /Factory/;


protected:
  void splitCurveAtVertexProtected( int index, QVector< double > &x1, QVector< double > &y1, QVector< double > &z1, QVector< double > &m1, QVector< double > &x2, QVector< double > &y2, QVector< double > &z2, QVector< double > &m2 ) const;

};

