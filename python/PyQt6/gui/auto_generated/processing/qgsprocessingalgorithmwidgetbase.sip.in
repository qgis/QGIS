class QgsProcessingAlgorithmWidgetBase : QDialog, QgsProcessingParametersGenerator, QgsProcessingContextGenerator
{
%Docstring(signature="appended")
Base class for widgets which contain settings for running Processing
algorithms.

.. note::

   This is not considered stable API and may change in future QGIS versions.
%End

%TypeHeaderCode
#include "qgsprocessingalgorithmwidgetbase.h"
%End
  public:
    enum class LogFormat /BaseType=IntEnum/
    {
      FormatPlainText,
      FormatHtml,
    };

    enum class WidgetMode /BaseType=IntEnum/
    {
      Single,
      Batch,
    };

    QgsProcessingAlgorithmWidgetBase( QWidget *parent /TransferThis/ = 0, QgsProcessingAlgorithmWidgetBase::WidgetMode mode = QgsProcessingAlgorithmWidgetBase::WidgetMode::Single );
%Docstring
Constructor for QgsProcessingAlgorithmWidgetBase.
%End
    ~QgsProcessingAlgorithmWidgetBase();

    void setAlgorithm( QgsProcessingAlgorithm *algorithm /Transfer/ );
%Docstring
Sets the ``algorithm`` to run in the widget.

Ownership of the algorithm instance is transferred to the widget.

.. seealso:: :py:func:`algorithm`
%End

    QgsProcessingAlgorithm *algorithm();
%Docstring
Returns the algorithm running in the widget.

.. seealso:: :py:func:`setAlgorithm`
%End

    void setMainWidget( QgsPanelWidget *widget /Transfer/ );
%Docstring
Sets the main ``widget`` for the widget, usually a panel for configuring
algorithm parameters.

.. seealso:: :py:func:`mainWidget`
%End

    QgsPanelWidget *mainWidget();
%Docstring
Returns the main widget for the widget, usually a panel for configuring
algorithm parameters.

.. seealso:: :py:func:`setMainWidget`
%End

    void showWidget();
%Docstring
Shows and raises the widget

.. versionadded:: 4.2
%End

    void showLog();
%Docstring
Switches the widget to the log page.
%End

    bool wasExecuted() const;
%Docstring
Returns ``True`` if an algorithm was executed in the widget.

.. seealso:: :py:func:`results`

.. seealso:: :py:func:`setExecuted`
%End

    QVariantMap results() const;
%Docstring
Returns the results returned by the algorithm executed.

.. seealso:: :py:func:`wasExecuted`

.. seealso:: :py:func:`setResults`
%End

    QgsProcessingFeedback *createFeedback() /Factory/;
%Docstring
Creates a new processing feedback object, automatically connected to the
appropriate slots in this widget.
%End

    void saveLogToFile( const QString &path, QgsProcessingAlgorithmWidgetBase::LogFormat format = QgsProcessingAlgorithmWidgetBase::LogFormat::FormatPlainText );
%Docstring
Saves the log contents to a text file (specified by the file ``path``),
in the given ``format``.

.. seealso:: :py:func:`saveLog`

.. versionadded:: 3.2
%End

    Qgis::ProcessingLogLevel logLevel() const;
%Docstring
Returns the logging level to use when running algorithms from the
widget.

.. seealso:: :py:func:`setLogLevel`

.. versionadded:: 3.20
%End

    void setLogLevel( Qgis::ProcessingLogLevel level );
%Docstring
Sets the logging ``level`` to use when running algorithms from the
widget.

.. seealso:: :py:func:`logLevel`

.. versionadded:: 3.20
%End

    virtual void setParameters( const QVariantMap &values );
%Docstring
Sets the parameter ``values`` to show in the widget.

.. versionadded:: 3.24
%End

    QPushButton *cancelButton();
%Docstring
Returns the widget's cancel button.
%End

  public slots:

    void reportError( const QString &error, bool fatalError );
%Docstring
Reports an ``error`` string to the widget's log.

If ``fatalError`` is ``True``, the error prevented the algorithm from
executing.
%End

    void pushWarning( const QString &warning );
%Docstring
Pushes a warning information string to the widget's log.
%End

    void pushInfo( const QString &info );
%Docstring
Pushes an information string to the widget's log.
%End

    void pushFormattedMessage( const QString &html );
%Docstring
Pushes a pre-formatted message to the widget's log

This can be used to push formatted HTML messages to the widget.

.. versionadded:: 3.36
%End

    void pushDebugInfo( const QString &message );
%Docstring
Pushes a debug info string to the widget's log.
%End

    void pushCommandInfo( const QString &info );
%Docstring
Pushes command info to the widget's log.
%End

    void setPercentage( double percent );
%Docstring
Sets the percentage progress for the widget, between 0 and 100.
%End

    void setProgressText( const QString &text );
%Docstring
Sets a progress text message.
%End

    void pushConsoleInfo( const QString &info );
%Docstring
Pushes a console info string to the widget's log.
%End

    QDialog *createProgressDialog();
%Docstring
Creates a modal progress dialog showing progress and log messages from
this widget.
%End

    void clearLog();
%Docstring
Clears the current log contents.

.. versionadded:: 3.2
%End

    void saveLog();
%Docstring
Opens a dialog allowing users to save the current log contents.

.. seealso:: :py:func:`saveLogToFile`

.. versionadded:: 3.2
%End

    void copyLogToClipboard();
%Docstring
Copies the current log contents to the clipboard.

.. versionadded:: 3.2
%End

    void showParameters();
%Docstring
Switches the widget to the parameters page.
%End

    void resetGui();
%Docstring
Resets the widget's GUI, ready for another algorithm execution.
%End

    virtual bool isRunning();
%Docstring
Returns ``True`` if the widget is currently running an algorithm.

If the algorithm has not yet started or has finished executing then
``False`` will be returned.

.. note::

   Unlike the :py:func:`~QgsProcessingAlgorithmWidgetBase.isFinalized` method, :py:func:`~QgsProcessingAlgorithmWidgetBase.isRunning` only provides
   information about the state of widget and is not tied to the
   deletion mechanisms of the widget.

.. seealso:: :py:func:`isFinalized`

.. versionadded:: 4.2
%End

    void forceClose();
%Docstring
Forces the widget to close by detaching any running task from the widget
THEN closing the widget.

.. versionadded:: 4.2
%End

    virtual void reject();


  protected:
    virtual void closeEvent( QCloseEvent *e );


    QPushButton *runButton();
%Docstring
Returns the widget's run button.
%End

    QPushButton *changeParametersButton();
%Docstring
Returns the widget's change parameters button.
%End

